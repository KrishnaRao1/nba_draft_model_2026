```{r comps}
comps <- prospects_2026 |>
  select(prospect      = player,
         prospect_age  = est_age,
         prospect_ts   = ts,
         prospect_usg  = usg,
         energy_2026   = energy) |>
  rowwise() |>
  mutate(
    comp = list(
      all_prospects |>
        filter(abs(est_age - prospect_age) <= 1) |>
        mutate(energy_diff = abs(energy - energy_2026)) |>
        arrange(energy_diff) |>
        slice_head(n = 1) |>
        select(comp_player = player,
               comp_age    = est_age,
               comp_ts     = ts,
               comp_usg    = usg)
    )
  ) |>
  unnest(comp) |>
  ungroup() |>
  arrange(desc(energy_2026)) |>
  select(prospect, prospect_age, prospect_ts, prospect_usg,
         comp_player, comp_age, comp_ts, comp_usg)

View(comps, title = "Comps")
```
