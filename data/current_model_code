```{r make-pos-table}
make_pos_table <- function(df, position) {
  df |>
    filter(pos_group == position) |>
    arrange(pos_rank) |>
    select(pos_rank, player, est_age, height, wingspan, weight_lbs,
           team, conf, energy, bpm, ortg, ts, usg)
}
```

